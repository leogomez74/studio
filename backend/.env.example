# ─── ERP CRM Federation v1.0 F4 ─────────────────────────────────────────
# Outbound sync Lead/Opportunity → CRM del ERP central (erp2026).
# Default OFF: activar solo cuando ingestion_token esté emitido en el ERP
# y este PEP instance esté linked a una company del ERP (ERP_COMPANY_ID).
#
# Cómo emitir el token (en el ERP, NO acá):
#   php artisan crm:issue-ingestion-token --company=<slug> --source=pep --label=production
# Copiar el plain-text Bearer que imprime → setear acá como ERP_INGESTION_TOKEN.
# Token tiene ability `crm:ingest` (Sanctum PAT, no JWT).
#
# ERP_API_EMAIL/PASSWORD se mantienen para ErpAccountingService (otro flujo).
ERP_API_URL=
ERP_API_EMAIL=
ERP_API_PASSWORD=
ERP_CRM_SYNC_ENABLED=false
ERP_INGESTION_TOKEN=
ERP_COMPANY_ID=
ERP_API_VERSION=2026-05

VITE_APP_NAME="${APP_NAME}"
